{
  "apiVersion": 3,
  "name": "badegg/post-masthead",
  "title": "Post Masthead",
  "category": "text",
  "icon": {
    "src": "edit",
    "foreground": "#f58762"
  },
  "description": "Display the title, first category, and author name.",
  "keywords": ["title", "author", "category", "meta"],

  "acf": {
    "mode": "preview",
    "validate": "false",
    "renderCallback": "\\App\\Blocks\\render_acf"
  },
  "supports": {
    "html": true,
    "multiple": false,
    "color": {
      "background": false,
      "text": false
    }
  },
  "attributes": {
    "category": {
      "type": "string"
    },
    "author": {
      "type": "string"
    }
  }
}
